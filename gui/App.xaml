<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="VRStickScope.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>
            <SolidColorBrush x:Key="BgDarkBrush" Color="#0D0F14" />
            <SolidColorBrush x:Key="BgCardBrush" Color="#161A24" />
            <SolidColorBrush x:Key="AccentBlueBrush" Color="#4F9EFF" />
            <SolidColorBrush x:Key="AccentGreenBrush" Color="#3DDC84" />
            <SolidColorBrush x:Key="AccentOrangeBrush" Color="#FF9500" />
            <SolidColorBrush x:Key="AccentRedBrush" Color="#FF3B5C" />
            <SolidColorBrush x:Key="TextPrimaryBrush" Color="#E8EBF0" />
            <SolidColorBrush x:Key="TextSecondaryBrush" Color="#8A9BB0" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
