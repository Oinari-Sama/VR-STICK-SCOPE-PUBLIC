<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="VRStickScope.Pages.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:VRStickScope.Controls"
    Background="Transparent">
    <ScrollViewer Padding="24">
        <StackPanel Spacing="16">
            <TextBlock x:Name="DashboardTitle" Text="Live input" FontSize="28" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
            <StackPanel Orientation="Horizontal" Spacing="8">
                <ToggleButton x:Name="BtnLeft" Content="Left stick" IsChecked="True" Click="BtnLeft_Click" />
                <ToggleButton x:Name="BtnRight" Content="Right stick" Click="BtnRight_Click" />
                <Button x:Name="ResetDiagnosticsButton" Content="Reset view" Click="ResetDiagnosticsButton_Click" />
            </StackPanel>
            <TextBlock x:Name="DiagnosticHelpText"
                       TextWrapping="Wrap"
                       Foreground="{StaticResource TextSecondaryBrush}" />
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Spacing="8">
                    <TextBlock x:Name="LeftTitle" Text="Left" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold" />
                    <controls:StickPlotControl x:Name="LeftPlot" Height="260" />
                    <TextBlock x:Name="LeftRawX" Text="Raw X: 0.000" Foreground="{StaticResource TextSecondaryBrush}" />
                    <TextBlock x:Name="LeftRawY" Text="Raw Y: 0.000" Foreground="{StaticResource TextSecondaryBrush}" />
                    <TextBlock x:Name="LeftCorX" Text="Corrected X: 0.000" Foreground="{StaticResource TextSecondaryBrush}" />
                    <TextBlock x:Name="LeftCorY" Text="Corrected Y: 0.000" Foreground="{StaticResource TextSecondaryBrush}" />
                </StackPanel>
                <StackPanel Grid.Column="1" Spacing="8">
                    <TextBlock x:Name="RightTitle" Text="Right" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold" />
                    <controls:StickPlotControl x:Name="RightPlot" Height="260" />
                    <TextBlock x:Name="RightRawX" Text="Raw X: 0.000" Foreground="{StaticResource TextSecondaryBrush}" />
                    <TextBlock x:Name="RightRawY" Text="Raw Y: 0.000" Foreground="{StaticResource TextSecondaryBrush}" />
                    <TextBlock x:Name="RightCorX" Text="Corrected X: 0.000" Foreground="{StaticResource TextSecondaryBrush}" />
                    <TextBlock x:Name="RightCorY" Text="Corrected Y: 0.000" Foreground="{StaticResource TextSecondaryBrush}" />
                </StackPanel>
            </Grid>
            <controls:PolarChartControl x:Name="PolarChart" Height="320" />
        </StackPanel>
    </ScrollViewer>
</Page>
