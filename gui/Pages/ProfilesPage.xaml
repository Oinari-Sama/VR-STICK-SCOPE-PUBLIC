<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="InariKontroller.Pages.ProfilesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">
    <Grid Padding="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <StackPanel Spacing="8">
            <TextBlock x:Name="ProfilesTitle" Text="Profiles" FontSize="28" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button x:Name="BtnNew" Content="New" Click="BtnNew_Click" />
                <Button x:Name="BtnOpenFolder" Content="Open Folder" Click="BtnOpenFolder_Click" />
                <Button x:Name="BtnRefresh" Content="Refresh" Click="BtnRefresh_Click" />
            </StackPanel>
        </StackPanel>
        <ListView x:Name="ProfileList" Grid.Row="1" SelectionChanged="ProfileList_SelectionChanged">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="8" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                        <Button Grid.Column="1" Content="{Binding ApplyText}" Tag="{Binding Id}" Click="BtnApply_Click" />
                        <Button Grid.Column="2" Content="{Binding DeleteText}" Tag="{Binding Id}" Click="BtnDelete_Click" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>

