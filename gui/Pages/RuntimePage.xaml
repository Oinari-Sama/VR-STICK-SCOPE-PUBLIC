<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="VRStickScope.Pages.RuntimePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">
    <ScrollViewer Padding="24">
        <StackPanel Spacing="18" MaxWidth="760" HorizontalAlignment="Left">
            <TextBlock x:Name="RuntimeTitle" Text="エンジン起動とVRChat出力" FontSize="28" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />

            <Border Background="{StaticResource BgCardBrush}" CornerRadius="8" Padding="16">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="EngineSectionTitle" Text="診断エンジン" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock x:Name="EnginePathText" Text="エンジンパス: 確認中..." Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" />
                    <TextBlock x:Name="EngineRunText" Text="エンジン状態: 確認中" Foreground="{StaticResource TextSecondaryBrush}" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button x:Name="BtnStartDiagnostics" Content="診断だけ開始" Click="BtnStartDiagnostics_Click" />
                        <Button x:Name="BtnStartOsc" Content="VRChatへ補正入力を送る" Click="BtnStartOsc_Click" />
                        <Button x:Name="BtnStopEngine" Content="エンジン停止" Click="BtnStopEngine_Click" />
                        <Button x:Name="BtnRefresh" Content="状態を更新" Click="BtnRefresh_Click" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Background="{StaticResource BgCardBrush}" CornerRadius="8" Padding="16">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="AutoStartSectionTitle" Text="SteamVR自動起動の解除" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock x:Name="AutoStartText" Text="SteamVR自動起動: 確認中..." Foreground="{StaticResource TextSecondaryBrush}" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button x:Name="BtnDisableAutoStart" Content="SteamVR自動起動を解除" Click="BtnDisableAutoStart_Click" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Background="{StaticResource BgCardBrush}" CornerRadius="8" Padding="16">
                <StackPanel Spacing="8">
                    <TextBlock x:Name="VrChatOscSectionTitle" Text="VRChat OSC出力" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock x:Name="VrChatOscHelpText" Text="この画面で開始したときだけ、補正後の移動入力と右スティックの左右旋回をVRChatのOSCポート 127.0.0.1:9000 へ送ります。停止時とアプリ終了時はOSC入力を0へ戻します。" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
