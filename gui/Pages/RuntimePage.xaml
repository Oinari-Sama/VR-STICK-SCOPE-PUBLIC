<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="InariKontroller.Pages.RuntimePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">
    <ScrollViewer Padding="24">
        <StackPanel Spacing="18" MaxWidth="760" HorizontalAlignment="Left">
            <TextBlock x:Name="RuntimeTitle" Text="VRChat出力とSteamVR自動起動" FontSize="28" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />

            <Border Background="{StaticResource BgCardBrush}" CornerRadius="8" Padding="16">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="VrChatOscSectionTitle" Text="VRChat OSC出力" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock x:Name="VrChatOscHelpText" Text="補正後の移動入力と旋回入力をVRChatのOSCポート 127.0.0.1:9000 へ送ります。停止時とアプリ終了時はOSC入力を0へ戻します。" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button x:Name="BtnStartOsc" Content="VRChatへ補正入力を送る" Click="BtnStartOsc_Click" />
                        <Button x:Name="BtnStopOsc" Content="VRChat出力を停止" Click="BtnStopOsc_Click" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Background="{StaticResource BgCardBrush}" CornerRadius="8" Padding="16">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="AutoStartSectionTitle" Text="SteamVR自動起動" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock x:Name="AutoStartText" Text="SteamVR自動起動: 確認中..." Foreground="{StaticResource TextSecondaryBrush}" />
                    <TextBlock x:Name="AutoStartHelpText" Text="有効にすると、SteamVR起動時にVRChat OSC補正を開始します。不要になったら解除してください。" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button x:Name="BtnEnableAutoStart" Content="SteamVR自動起動を有効化" Click="BtnEnableAutoStart_Click" />
                        <Button x:Name="BtnDisableAutoStart" Content="SteamVR自動起動を解除" Click="BtnDisableAutoStart_Click" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
